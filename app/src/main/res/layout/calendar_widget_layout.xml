            android:id="@+id/calendar_widget_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="জুন ২০২৬"
            android:textColor="#E5A11E"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/calendar_widget_extra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="১৩৮২ বঙ্গাব্দ | ১৪৪৭ হিজরি"
            android:textColor="#8BBDAF"
            android:textSize="9sp"
            android:textStyle="bold" />
    </RelativeLayout>

